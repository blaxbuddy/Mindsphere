modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"

hidden = [".config", ".git", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"
DATABASE_URL = "$REPLIT_DB_URL"

[deployment]
deploymentTarget = "cloudrun"
run = ["npm", "start"]

[workflows]
runButton = "Start Server"

[[workflows.workflow]]
name = "Start Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000